# ============================================================
# Root .env — đọc bởi docker-compose.yml (auto)
# Copy file này thành `.env` rồi điền giá trị thật.
# .env đã có trong .gitignore — KHÔNG commit secrets.
# ============================================================

# ---------- PostgreSQL (compose) ----------
DB_NAME=pacs_db
DB_USER=pacs_user
DB_PASS=change_me_to_strong_password
DB_PORT=5432

# ---------- Orthanc (compose) ----------
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242

# Lưu ý: cấu hình runtime của backend (JWT_SECRET, OLLAMA_URL, GEMINI_API_KEY...)
# nằm trong backend-v2/.env — xem backend-v2/.env.example
